# Copy this file to `.env` (same folder) and fill in your values.
# `.env` is gitignored — never commit a real token.

TELEGRAM_BOT_TOKEN=paste-your-token-here

# Which database to use: "local" (docker compose up -d db) or "supabase"
# (the shared team DB). Flip this one word to switch.
DB_TARGET=local

# Local/offline Postgres (matches docker-compose.yml; usually leave as is).
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5433/panen

# Supabase: use the SESSION POOLER string from Dashboard -> Connect
# (host like aws-0-<region>.pooler.supabase.com, port 5432). The "direct
# connection" string is IPv6-only and fails on most networks.
DATABASE_URL_SUPABASE=

# Optional: price data mode (cache = default, demo-safe; live = try PIHPS first)
# PRICE_SOURCE=cache

ADMIN_TELEGRAM_ID=
